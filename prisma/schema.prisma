generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String
  icon      String?
  isPreset  Boolean   @default(false)
  createdAt DateTime  @default(now())
  expenses  Expense[]
}

model Income {
  id        String   @id @default(cuid())
  label     String
  amount    Float
  month     Int
  year      Int
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id         String   @id @default(cuid())
  label      String
  amount     Float
  month      Int
  year       Int
  date       DateTime
  note       String?
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
